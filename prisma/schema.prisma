generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id        String   @id @default(cuid())
  company   String
  role      String
  status    Status   @default(APPLIED)
  location  String?
  url       String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Status {
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}
